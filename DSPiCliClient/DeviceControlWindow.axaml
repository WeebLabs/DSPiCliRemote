<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DSPiCliClient"
        x:Class="DSPiCliClient.DeviceControlWindow"
        x:DataType="local:DeviceViewModel"
        Title="Device Control" Width="400" Height="450">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Master Volume (dB)" FontWeight="Bold"/>
        <DockPanel>
            <TextBlock Name="VolumeText" Width="40" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <Slider Name="VolumeSlider" Minimum="-127" Maximum="0" Value="-20" />
        </DockPanel>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Name="LoudnessButton" Content="Loudness: Unknown" HorizontalAlignment="Stretch" Click="OnLoudnessClick"/>
            <Button Name="LevelingButton" Content="Leveling: Unknown" HorizontalAlignment="Stretch" Click="OnLevelingClick"/>
            <Button Name="CrossfeedButton" Content="Crossfeed: Unknown" HorizontalAlignment="Stretch" Click="OnCrossfeedClick"/>
        </StackPanel>

        <Separator/>

        <StackPanel Spacing="5">
            <TextBlock Text="Preset:" FontWeight="Bold"/>
            <ComboBox Name="PresetComboBox" HorizontalAlignment="Stretch" 
                      ItemsSource="{Binding PresetList}"
                      SelectedItem="{Binding SelectedPreset}"
                      SelectionChanged="OnPresetSelectionChanged">
            </ComboBox>
        </StackPanel>

        <Separator/>

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,10,0,0">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sample Rate:" Margin="0,0,10,5"/>
            <TextBlock Name="SampleRateText" Grid.Row="0" Grid.Column="1" Text="--- Hz" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Network Addr:" Margin="0,0,10,5"/>
            <TextBlock Name="NetworkAddrText" Grid.Row="1" Grid.Column="1" Text="---" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Device ID:" Margin="0,0,10,5"/>
            <TextBlock Name="DeviceIdText" Grid.Row="2" Grid.Column="1" Text="---" Margin="0,0,0,5"/>
        </Grid>

        <Button Content="Refresh Status" HorizontalAlignment="Right" Click="OnRefreshClick" Margin="0,20,0,0"/>
    </StackPanel>
</Window>
